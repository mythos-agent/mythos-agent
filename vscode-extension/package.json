{
  "name": "shedu-vscode",
  "displayName": "shedu — AI Security Scanner",
  "description": "Find vulnerabilities, chain them into attack paths, and auto-fix with AI. Mythos for everyone.",
  "version": "0.3.0",
  "publisher": "shedu",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "security",
    "vulnerability",
    "scanner",
    "ai",
    "owasp",
    "sast"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shedu.scanFile",
        "title": "shedu: Scan Current File"
      },
      {
        "command": "shedu.scanWorkspace",
        "title": "shedu: Scan Workspace"
      },
      {
        "command": "shedu.fixVulnerability",
        "title": "shedu: Fix Vulnerability with AI"
      },
      {
        "command": "shedu.clearDiagnostics",
        "title": "shedu: Clear All Diagnostics"
      }
    ],
    "configuration": {
      "title": "shedu",
      "properties": {
        "shedu.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan files for vulnerabilities on save"
        },
        "shedu.severity": {
          "type": "string",
          "default": "low",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Minimum severity level to display"
        },
        "shedu.enableSecrets": {
          "type": "boolean",
          "default": true,
          "description": "Enable secrets detection"
        },
        "shedu.enableAI": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI-powered deep analysis (requires API key)"
        },
        "shedu.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for AI features"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
