{
  "name": "sphinx-agent",
  "version": "2.0.2",
  "description": "Agentic AI security scanner — Mythos for everyone. Finds vulnerabilities, chains them into attack paths, and generates patches.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sphinx-agent": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "security",
    "vulnerability",
    "scanner",
    "ai",
    "claude",
    "cybersecurity",
    "owasp",
    "sast",
    "static-analysis",
    "agentic"
  ],
  "author": "sphinx-agent contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sphinx-agent/sphinx-agent.git"
  },
  "homepage": "https://github.com/sphinx-agent/sphinx-agent",
  "bugs": {
    "url": "https://github.com/sphinx-agent/sphinx-agent/issues"
  },
  "funding": "https://github.com/sponsors/zhijiewong",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "glob": "^11.0.0",
    "inquirer": "^12.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
