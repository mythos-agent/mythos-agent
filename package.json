{
  "name": "mythos-agent",
  "version": "4.2.0",
  "description": "Open-source AI code-review assistant for application security. Flags likely vulnerabilities in source code with reasoning and suggested fixes.",
  "mcpName": "io.github.mythos-agent/mythos-agent",
  "type": "module",
  "bin": {
    "mythos-agent": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "assets",
    "LICENSE",
    "README.md",
    "!dist/**/__tests__",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.map",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark:cve-replay": "tsc -p tsconfig.benchmarks.json && node dist-benchmarks/benchmarks/cve-replay/run.js",
    "benchmark:variants-calibration": "tsc -p tsconfig.benchmarks.json && node dist-benchmarks/benchmarks/variants-calibration/run.js",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "security",
    "vulnerability",
    "scanner",
    "ai",
    "cybersecurity",
    "sast",
    "static-analysis"
  ],
  "author": "mythos-agent contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mythos-agent/mythos-agent.git"
  },
  "homepage": "https://github.com/mythos-agent/mythos-agent",
  "bugs": {
    "url": "https://github.com/mythos-agent/mythos-agent/issues"
  },
  "funding": "https://github.com/sponsors/zhijiewong",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "glob": "^11.0.0",
    "inquirer": "^12.3.0",
    "js-yaml": "^4.1.0",
    "openai": "^6.34.0",
    "ora": "^8.2.0",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^3.0.0",
    "ajv": "^8.18.0",
    "ajv-draft-04": "^1.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
